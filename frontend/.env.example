# Copy this file to ".env" and fill in your Supabase project values.
# Find both under: Supabase Dashboard -> Project Settings -> API
#
# These are PUBLIC client keys (the anon key is safe to ship in a browser bundle;
# Row Level Security is what protects your data). Never put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
